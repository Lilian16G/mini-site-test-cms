<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
</head>
<body>

  <header>
    <nav>Mon Entreprise Test — Accueil | Services</nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <p>© 2026 Mon Entreprise Test</p>
  </footer>

<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", user => {
      if (!user) {
        window.netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>

</body>
</html>